<mvc:View controllerName="zpe2.co001.zpe2co001.controller.ActualCostDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="actualCostDetailPage" showHeader="false" class="actualCostDetailPage">
        <VBox class="sapUiSmallMargin">
            <Toolbar class="actualCostDetailToolbar">
                <Button
                    icon="sap-icon://nav-back"
                    type="Transparent"
                    tooltip="뒤로"
                    press=".onNavBack" />
                <Text text="실제원가 산정" class="actualCostDetailBreadcrumb" />
                <Title
                    level="H2"
                    text="{path: 'detail>/selection', formatter: '.formatHeaderTitle'}"
                    class="actualCostDetailTitle" />
                <ToolbarSpacer />
                <Button text="PDF 원가명세서 출력" type="Emphasized" press=".onPressPrintPdf" />
            <!--   <Button text="엑셀 다운로드" enabled="false" />--> 
                <Button icon="sap-icon://refresh" type="Transparent" tooltip="새로고침" press=".onRefresh" />
            </Toolbar>

            <HBox class="actualCostDetailSummary sapUiSmallMarginBottom" renderType="Bare">
                <VBox class="actualCostDetailSummaryItem">
                    <Label text="상태" />
                    <ObjectStatus text="산정완료" state="Success" class="actualCostDetailStatus" />
                </VBox>
                <VBox class="actualCostDetailSummaryItem">
                    <Label text="기간" />
                    <ObjectNumber number="{parts: [{path: 'detail>/selection/Bdatj'}, {path: 'detail>/selection/Poper'}], formatter: '.formatPeriod'}" />
                </VBox>
                <VBox class="actualCostDetailSummaryItem">
                    <Label text="생산수량 (계획)" />
                    <ObjectNumber
                        number="{parts: [{path: 'summary>/Gamng'}, {path: 'summary>/Meins'}], formatter: '.formatQuantity'}" />
                </VBox>
                <VBox class="actualCostDetailSummaryItem">
                    <Label text="완료수량 (실제)" />
                    <ObjectNumber
                        number="{parts: [{path: 'summary>/OkQty'}, {path: 'summary>/Meins'}], formatter: '.formatQuantity'}" />
                </VBox>
                <VBox class="actualCostDetailSummaryItem">
                    <Label text="실제단가" />
                    <ObjectNumber
                        number="{parts: [{path: 'summary>/Stprs'}, {path: 'summary>/Waers'}, {path: 'summary>/Meins'}], formatter: '.formatUnitCost'}" />
                </VBox>
                <VBox class="actualCostDetailSummaryItem">
                    <Label text="총 실제원가" />
                    <ObjectNumber
                        number="{parts: [{path: 'summary>/Wkg00'}, {path: 'summary>/Waers'}], formatter: '.formatCurrencyAmount'}" />
                </VBox>
            </HBox>

            <Panel
                headerText="생산오더별 원가 내역"
                class="actualCostDetailOrderPanel sapUiNoContentPadding sapUiSmallMarginBottom">
                <t:Table
                    id="actProdOrderTable"
                    class="actualCostTable actualCostProdOrderTable"
                    width="100%"
                    visibleRowCount="5"
                    minAutoRowCount="3"
                    rows="{detail>/prodOrders}"
                    selectionMode="None">
                    <t:columns>
                        <t:Column width="11%">
                            <Label text="생산오더번호" />
                            <t:template>
                                <Text text="{detail>Aufnr}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="10%">
                            <Label text="생산일자" />
                            <t:template>
                                <Text text="{path: 'detail>Qiactdat', formatter: '.formatDate'}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11%" hAlign="End">
                            <Label text="생산수량 (계획)" />
                            <t:template>
                                <Text text="{parts: [{path: 'detail>Gamng'}, {path: 'detail>Meins'}], formatter: '.formatQuantity'}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11%" hAlign="End">
                            <Label text="완료수량 (실제)" />
                            <t:template>
                                <Text text="{parts: [{path: 'detail>OkQty'}, {path: 'detail>Meins'}], formatter: '.formatQuantity'}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11%" hAlign="End">
                            <Label text="재료비" />
                            <t:template>
                                <Text text="{parts: [{path: 'detail>Dmatl'}, {path: 'detail>Waers'}], formatter: '.formatCurrencyAmount'}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11%" hAlign="End">
                            <Label text="노무비" />
                            <t:template>
                                <Text text="{parts: [{path: 'detail>Dlabr'}, {path: 'detail>Waers'}], formatter: '.formatCurrencyAmount'}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11%" hAlign="End">
                            <Label text="간접비" />
                            <t:template>
                                <Text text="{parts: [{path: 'detail>Mohad'}, {path: 'detail>Waers'}], formatter: '.formatCurrencyAmount'}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="13%" hAlign="End">
                            <Label text="총 실제원가" />
                            <t:template>
                                <Text text="{parts: [{path: 'detail>Wkg00'}, {path: 'detail>Waers'}], formatter: '.formatCurrencyAmount'}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11%" hAlign="End">
                            <Label text="실제단가" />
                            <t:template>
                                <Text text="{parts: [{path: 'detail>Stprs'}, {path: 'detail>Waers'}, {path: 'detail>Meins'}], formatter: '.formatUnitCost'}" wrapping="false" />
                            </t:template>
                        </t:Column>
                    </t:columns>
                </t:Table>
                <t:Table
                    id="actProdOrderSummaryTable"
                    class="actualCostTable actualCostProdOrderTable actualCostProdOrderSummaryTable"
                    width="100%"
                    visibleRowCount="1"
                    columnHeaderVisible="false"
                    rows="{summary>/rows}"
                    selectionMode="None">
                    <t:columns>
                        <t:Column width="11%">
                            <Label text="생산오더번호" />
                            <t:template>
                                <Label text="{summary>Aufnr}" design="Bold" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="10%">
                            <Label text="생산일자" />
                            <t:template>
                                <Label text="{summary>Qiactdat}" design="Bold" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11%" hAlign="End">
                            <Label text="생산수량 (계획)" />
                            <t:template>
                                <Label text="{parts: [{path: 'summary>Gamng'}, {path: 'summary>Meins'}], formatter: '.formatQuantity'}" design="Bold" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11%" hAlign="End">
                            <Label text="완료수량 (실제)" />
                            <t:template>
                                <Label text="{parts: [{path: 'summary>OkQty'}, {path: 'summary>Meins'}], formatter: '.formatQuantity'}" design="Bold" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11%" hAlign="End">
                            <Label text="재료비" />
                            <t:template>
                                <Label text="{parts: [{path: 'summary>Dmatl'}, {path: 'summary>Waers'}], formatter: '.formatCurrencyAmount'}" design="Bold" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11%" hAlign="End">
                            <Label text="노무비" />
                            <t:template>
                                <Label text="{parts: [{path: 'summary>Dlabr'}, {path: 'summary>Waers'}], formatter: '.formatCurrencyAmount'}" design="Bold" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11%" hAlign="End">
                            <Label text="간접비" />
                            <t:template>
                                <Label text="{parts: [{path: 'summary>Mohad'}, {path: 'summary>Waers'}], formatter: '.formatCurrencyAmount'}" design="Bold" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="13%" hAlign="End">
                            <Label text="총 실제원가" />
                            <t:template>
                                <Label text="{parts: [{path: 'summary>Wkg00'}, {path: 'summary>Waers'}], formatter: '.formatCurrencyAmount'}" design="Bold" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="11%" hAlign="End">
                            <Label text="실제단가" />
                            <t:template>
                                <Label text="{parts: [{path: 'summary>Stprs'}, {path: 'summary>Waers'}, {path: 'summary>Meins'}], formatter: '.formatUnitCost'}" design="Bold" wrapping="false" />
                            </t:template>
                        </t:Column>
                    </t:columns>
                </t:Table>
            </Panel>

            <HBox class="actualCostDetailBottomRow" renderType="Bare">
                <Panel
                    headerText="원가 구성 (총 실제원가)"
                    class="actualCostDetailChartPanel sapUiNoContentPadding">
                    <core:HTML content="{summary>/donutHtml}" sanitizeContent="false" />
                </Panel>

                <Panel headerText="상세 원가 구성" class="actualCostDetailTabs sapUiNoContentPadding">
                    <IconTabBar expandable="false">
                        <items>
                            <IconTabFilter key="material" text="재료비 내역">
                                <t:Table
                                    id="actMatTable"
                                    class="actualCostTable"
                                    visibleRowCount="6"
                                    rows="{detail>/materials}"
                                    selectionMode="None">
                                    <t:columns>
                                        <t:Column width="8rem">
                                            <Label text="자재번호" />
                                            <t:template>
                                                <Text text="{detail>Matnr}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                        <t:Column width="8rem">
                                            <Label text="자재명" />
                                            <t:template>
                                                <Text text="{detail>Maktx}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                        <t:Column width="8rem">
                                            <Label text="규격" />
                                            <t:template>
                                                <Text text="{parts: [{path: 'detail>Ntgew'}, {path: 'detail>Gewei'}, {path: 'detail>Meins'}], formatter: '.formatMaterialSpec'}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                        <t:Column width="4rem">
                                            <Label text="단위" />
                                            <t:template>
                                                <Text text="{detail>Meins}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                        <t:Column width="8rem" hAlign="End">
                                            <Label text="투입수량" />
                                            <t:template>
                                                <Text text="{parts: [{path: 'detail>Bdmng'}, {path: 'detail>Meins'}], formatter: '.formatQuantity'}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                        <t:Column width="8rem" hAlign="End">
                                            <Label text="금액" />
                                            <t:template>
                                                <Text text="{parts: [{path: 'detail>Wkg00'}, {path: 'detail>Waers'}], formatter: '.formatCurrencyAmount'}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                    </t:columns>
                                </t:Table>
                            </IconTabFilter>
                            <IconTabFilter key="labor" text="노무비 내역">
                                <t:Table
                                    id="actLabTable"
                                    class="actualCostTable"
                                    visibleRowCount="6"
                                    rows="{detail>/labors}"
                                    selectionMode="None">
                                    <t:columns>
                                        <t:Column width="7rem">
                                            <Label text="공정번호" />
                                            <t:template>
                                                <Text text="{detail>Vornr}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                        <t:Column width="8rem">
                                            <Label text="공정명" />
                                            <t:template>
                                                <Text text="{detail>Ltxa1}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                        <t:Column width="7rem">
                                            <Label text="작업장" />
                                            <t:template>
                                                <Text text="{detail>Arbpl}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                        <t:Column width="6rem">
                                            <Label text="작업장명" />
                                            <t:template>
                                                <Text text="{detail>Ktext}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                        <t:Column width="8.5rem" hAlign="End">
                                            <Label text="총시간" />
                                            <t:template>
                                                <Text text="{parts: [{path: 'detail>Ismnw'}, {path: 'detail>Vge02'}], formatter: '.formatTime'}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                        <t:Column width="8.5rem" hAlign="End">
                                            <Label text="노무비" />
                                            <t:template>
                                                <Text text="{parts: [{path: 'detail>Wkg00'}, {path: 'detail>Waers'}], formatter: '.formatCurrencyAmount'}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                    </t:columns>
                                </t:Table>
                            </IconTabFilter>
                            <IconTabFilter key="overhead" text="간접비 내역">
                                <t:Table
                                    id="actIndTable"
                                    class="actualCostTable"
                                    visibleRowCount="6"
                                    rows="{detail>/overheads}"
                                    selectionMode="None">
                                    <t:columns>
                                        <t:Column width="9rem">
                                            <Label text="원가요소" />
                                            <t:template>
                                                <Text text="{detail>Kstar}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                        <t:Column width="16rem">
                                            <Label text="원가요소명" />
                                            <t:template>
                                                <Text text="{detail>Ktext}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                        <t:Column width="8rem" hAlign="End">
                                            <Label text="총시간" />
                                            <t:template>
                                                <Text text="{parts: [{path: 'detail>Ismnw'}, {path: 'detail>Vge02'}], formatter: '.formatTime'}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                        <t:Column width="8rem" hAlign="End">
                                            <Label text="간접비" />
                                            <t:template>
                                                <Text text="{parts: [{path: 'detail>Wkg00'}, {path: 'detail>Waers'}], formatter: '.formatCurrencyAmount'}" wrapping="false" />
                                            </t:template>
                                        </t:Column>
                                    </t:columns>
                                </t:Table>
                            </IconTabFilter>
                        </items>
                    </IconTabBar>
                </Panel>
            </HBox>
        </VBox>
    </Page>
</mvc:View>
