<mvc:View controllerName="zpe2.co001.zpe2co001.controller.ActualCostView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page id="page" showHeader="false">
        <VBox class="sapUiSmallMargin">
            <Panel expandable="false" class="actualCostFilterBar sapUiNoContentPadding sapUiSmallMarginBottom">
                <VBox class="sapUiSmallMargin">
                    <HBox alignItems="End" wrap="Wrap">
                        <VBox width="12rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                            <Label text="연도" required="true" />
                            <ComboBox
                                id="yearComboBox"
                                width="100%"
                                selectedKey="{view>/year}">
                                <core:Item key="2021" text="2021" />
                                <core:Item key="2022" text="2022" />
                                <core:Item key="2023" text="2023" />
                                <core:Item key="2024" text="2024" />
                                <core:Item key="2025" text="2025" />
                                <core:Item key="2026" text="2026" />
                            </ComboBox>
                        </VBox>
                        <VBox width="12rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                            <Label text="월" required="true" />
                            <ComboBox
                                id="monthComboBox"
                                width="100%"
                                selectedKey="{view>/month}">
                                <core:Item key="001" text="01" />
                                <core:Item key="002" text="02" />
                                <core:Item key="003" text="03" />
                                <core:Item key="004" text="04" />
                                <core:Item key="005" text="05" />
                                <core:Item key="006" text="06" />
                                <core:Item key="007" text="07" />
                                <core:Item key="008" text="08" />
                                <core:Item key="009" text="09" />
                                <core:Item key="010" text="10" />
                                <core:Item key="011" text="11" />
                                <core:Item key="012" text="12" />
                            </ComboBox>
                        </VBox>
                        <VBox width="18rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                            <Label text="자재코드" />
                            <Input
                                id="materialInput"
                                placeholder="자재코드"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpRequest" />
                        </VBox>
                    <VBox width="14rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                            <Label text="산정상태" />
                            <ComboBox
                                id="statusComboBox"
                                width="100%"
                                selectedKey="">
                                <core:Item key="" text="전체" />
                                <core:Item key="Y" text="산정완료" />
                                <core:Item key="N" text="산정전" />
                            </ComboBox>
                        </VBox>
                        <Button
                            text="조회"
                            type="Emphasized"
                            press=".onSearch"
                            class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                            width="4rem" />
                        <Button
                            text="필터 초기화"
                            press=".onResetSearch"
                            class="sapUiTinyMarginBottom" />
                    </HBox>
                </VBox>
            </Panel>

            <HBox class="actualCostSummary sapUiSmallMarginBottom" renderType="Bare">
                <HBox class="actualCostSummaryItem" alignItems="Center" justifyContent="Start">
                    <Avatar
                        src="sap-icon://product"
                        displayShape="Circle"
                        class="actualCostSummaryIcon actualCostSummaryIconAll" />
                    <VBox class="actualCostSummaryText">
                        <Text text="전체 자재" />
                        <ObjectNumber number="{view>/summary/total}" unit="건" />
                    </VBox>
                </HBox>
                <HBox class="actualCostSummaryItem" alignItems="Center" justifyContent="Start">
                    <Avatar
                        src="sap-icon://sys-enter"
                        displayShape="Circle"
                        class="actualCostSummaryIcon actualCostSummaryIconComplete" />
                    <VBox class="actualCostSummaryText">
                        <Text text="산정완료" />
                        <ObjectNumber number="{view>/summary/completed}" unit="건" state="Success" />
                    </VBox>
                </HBox>
                <HBox class="actualCostSummaryItem" alignItems="Center" justifyContent="Start">
                    <Avatar
                        src="sap-icon://message-warning"
                        displayShape="Circle"
                        class="actualCostSummaryIcon actualCostSummaryIconPending" />
                    <VBox class="actualCostSummaryText">
                        <Text text="산정전" />
                        <ObjectNumber number="{view>/summary/pending}" unit="건" state="Error" />
                    </VBox>
                </HBox>
            </HBox>

            <t:Table
                id="actualCostTable"
                class="actualCostTable"
                visibleRowCount="12"
                rows="{view>/items}"
                selectionMode="None"
                ariaLabelledBy="actualCostTitle">
                <t:extension>
                    <OverflowToolbar style="Clear">
                        <Title id="actualCostTitle" text="자재 목록 ({view>/summary/total})" />
                    </OverflowToolbar>
                </t:extension>
                <t:columns>
                    <t:Column width="7rem">
                        <Label text="자재번호" />
                        <t:template>
                            <Text text="{view>Matnr}" wrapping="false" />
                        </t:template>
                    </t:Column>
                    <t:Column width="10rem">
                        <Label text="자재명" />
                        <t:template>
                            <Text text="{view>Maktx}" wrapping="false" />
                        </t:template>
                    </t:Column>
                    <t:Column width="7rem" hAlign="End">
                        <Label text="생산수량 (계획)" />
                        <t:template>
                            <Text
                                text="{
                                    parts: [{path: 'view>Gamng'}, {path: 'view>Meins'}],
                                    type: 'sap.ui.model.type.Unit',
                                    formatOptions: {showMeasure: true}
                                }"
                                wrapping="false" />
                        </t:template>
                    </t:Column>
                    <t:Column width="7rem" hAlign="End">
                        <Label text="완료수량 (실제)" />
                        <t:template>
                            <Text
                                text="{parts: [{path: 'view>ActQty'}, {path: 'view>Meins'}, {path: 'view>Stat'}], formatter: '.formatActualQuantity'}"
                                wrapping="false" />
                        </t:template>
                    </t:Column>
                    <t:Column width="7.5rem" hAlign="End">
                        <Label text="재료비" />
                        <t:template>
                            <Text text="{parts: [{path: 'view>Dmatl'}, {path: 'view>Waers'}, {path: 'view>Stat'}], formatter: '.formatActualCurrencyAmount'}" wrapping="false" />
                        </t:template>
                    </t:Column>
                    <t:Column width="7.5rem" hAlign="End">
                        <Label text="노무비" />
                        <t:template>
                            <Text text="{parts: [{path: 'view>Dlabr'}, {path: 'view>Dlabl'}, {path: 'view>Waers'}, {path: 'view>Stat'}], formatter: '.formatActualCurrencyAmountFallback'}" wrapping="false" />
                        </t:template>
                    </t:Column>
                    <t:Column width="7.5rem" hAlign="End">
                        <Label text="간접비" />
                        <t:template>
                            <Text text="{parts: [{path: 'view>Mohad'}, {path: 'view>Mmach'}, {path: 'view>Waers'}, {path: 'view>Stat'}], formatter: '.formatActualCurrencyAmountFallback'}" wrapping="false" />
                        </t:template>
                    </t:Column>
                    <t:Column width="8rem" hAlign="End">
                        <Label text="총 실제원가" />
                        <t:template>
                            <Text text="{parts: [{path: 'view>Wkg00'}, {path: 'view>Waers'}, {path: 'view>Stat'}], formatter: '.formatActualCurrencyAmount'}" wrapping="false" />
                        </t:template>
                    </t:Column>
                    <t:Column width="8rem" hAlign="End">
                        <Label text="실제단가" />
                        <t:template>
                            <Text text="{parts: [{path: 'view>Stprs'}, {path: 'view>Waers'}, {path: 'view>Meins'}, {path: 'view>Stat'}], formatter: '.formatActualUnitCost'}" wrapping="false" />
                        </t:template>
                    </t:Column>
                    <t:Column width="6.5rem" hAlign="Center">
                        <Label text="산정상태" />
                        <t:template>
                            <ObjectStatus
                                text="{path: 'view>Stat', formatter: '.formatCostStatusText'}"
                                state="{path: 'view>Stat', formatter: '.formatCostStatusState'}"
                                class="actualCostStatusText" />
                        </t:template>
                    </t:Column>
                    <t:Column width="5.4rem" hAlign="Center">
                        <Label text="산정" />
                        <t:template>
                            <Button
                                text="산정"
                                type="Default"
                                width="4rem"
                                class="actualCostCalculateButton"
                                visible="{path: 'view>Stat', formatter: '.formatCalculateButtonVisible'}"
                                press=".onPressCalculate" />
                        </t:template>
                    </t:Column>
                    <t:Column width="4rem" hAlign="Center">
                        <Label text="상세" />
                        <t:template>
                            <Button
                                icon="sap-icon://navigation-right-arrow"
                                type="Transparent"
                                tooltip="상세"
                                press=".onPressDetail" />
                        </t:template>
                    </t:Column>
                </t:columns>
            </t:Table>
        </VBox>
    </Page>
</mvc:View>
