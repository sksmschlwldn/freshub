<mvc:View controllerName="zpe2.pp001.zpe2pp001.controller.ProdDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="prodDetailPage" title="생산 상세" showNavButton="true" navButtonPress=".onNavBack">
        <VBox class="sapUiSmallMargin">
            <Panel headerText="생산오더 정보" expandable="false">
                <VBox class="sapUiSmallMargin prodDetailInfo">
                    <HBox wrap="Wrap" class="prodDetailInfoLine" alignItems="Center">
                        <HBox class="prodDetailField" alignItems="Center">
                            <Label text="생산오더번호" class="prodDetailLabel" />
                            <Text text=":" class="prodDetailColon" />
                            <Input value="{Aufnr}" editable="false" width="10rem" />
                        </HBox>
                        <HBox class="prodDetailField" alignItems="Center">
                            <Label text="생산상태" class="prodDetailLabel" />
                            <Text text=":" class="prodDetailColon" />
                            <Input value="{path: 'Stat', formatter: '.formatProdStatusText'}" editable="false" width="10rem" />
                        </HBox>
                    </HBox>
                    <HBox wrap="Wrap" class="prodDetailInfoLine" alignItems="Center">
                        <HBox class="prodDetailField" alignItems="Center">
                            <Label text="자재번호" class="prodDetailLabel" />
                            <Text text=":" class="prodDetailColon" />
                            <Input value="{Plnbez}" editable="false" width="10rem" />
                        </HBox>
                        <HBox class="prodDetailField" alignItems="Center">
                            <Label text="자재명" class="prodDetailLabel" />
                            <Text text=":" class="prodDetailColon" />
                            <Input value="{Maktx}" editable="false" width="14rem" />
                        </HBox>
                        <HBox class="prodDetailField" alignItems="Center">
                            <Label text="생산수량" class="prodDetailLabel" />
                            <Text text=":" class="prodDetailColon" />
                            <Input
                                value="{
                                    parts:[{path:'Gamng'},{path:'Meins'}],
                                    formatter: '.formatProdQuantity'
                                }"
                                editable="false"
                                width="10rem" />
                        </HBox>
                    </HBox>
                    <HBox wrap="Wrap" class="prodDetailInfoLine" alignItems="Center">
                        <HBox class="prodDetailField prodDetailWideField" alignItems="Center">
                            <Label text="계획일" class="prodDetailLabel" />
                            <Text text=":" class="prodDetailColon" />
                            <Input
                                value="{
                                    parts:[{path:'Gstrp'},{path:'Gltrp'}],
                                    formatter: '.formatPlanDateRange'
                                }"
                                editable="false"
                                width="18rem" />
                        </HBox>
                    </HBox>
                    <HBox wrap="Wrap" class="prodDetailInfoLine" alignItems="Center">
                        <HBox class="prodDetailField" alignItems="Center">
                            <Label text="BOM ID" class="prodDetailLabel" />
                            <Text text=":" class="prodDetailColon" />
                            <Input value="{Stlnr}" editable="false" width="10rem" />
                        </HBox>
                        <HBox class="prodDetailField" alignItems="Center">
                            <Label text="공정 ID" class="prodDetailLabel" />
                            <Text text=":" class="prodDetailColon" />
                            <Input value="{Plnnr}" editable="false" width="10rem" />
                        </HBox>
                    </HBox>
                </VBox>
            </Panel>

            <Panel headerText="공정 실적" expandable="false" class="sapUiSmallMarginTop">
                <VBox class="sapUiSmallMargin">
                    <Text text="공정 조회 및 실적 입력 영역" />
                </VBox>
            </Panel>
        </VBox>
    </Page>
</mvc:View>
