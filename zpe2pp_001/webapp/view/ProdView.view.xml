<mvc:View controllerName="zpe2.pp001.zpe2pp001.controller.ProdView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <VBox class="sapUiSmallMargin">
            <Panel headerText="조회조건" expandable="false" class="sapUiNoContentPadding sapUiSmallMarginBottom">
                <VBox class="sapUiSmallMargin">
                    <HBox alignItems="End" wrap="Wrap">
                        <VBox width="12rem" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                            <Label text="생산오더번호" />
                            <Input id="aufnrInput" placeholder="생산오더번호" />
                        </VBox>
                        <VBox width="12rem" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                            <Label text="자재번호" />
                            <Input id="plnbezInput" placeholder="자재번호" />
                        </VBox>
                        <VBox width="21rem" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                            <Label text="계획시작일" />
                            <HBox alignItems="Center">
                                <DatePicker
                                    id="gstrpFromDate"
                                    width="9rem"
                                    displayFormat="yyyy.MM.dd"
                                    valueFormat="yyyy.MM.dd" />
                                <Text text="~" class="sapUiTinyMarginBeginEnd" />
                                <DatePicker
                                    id="gstrpToDate"
                                    width="9rem"
                                    displayFormat="yyyy.MM.dd"
                                    valueFormat="yyyy.MM.dd" />
                            </HBox>
                        </VBox>
                        <VBox width="10rem" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                            <Label text="생산상태" />
                            <Select id="statSelect" width="100%">
                                <core:Item key="ALL" text="전체" />
                                <core:Item key="" text="미진행" />
                                <core:Item key="1" text="진행중" />
                                <core:Item key="2" text="완료" />
                                <core:Item key="3" text="취소" />
                            </Select>
                        </VBox>
                        <Button
                            text="조회"
                            icon="sap-icon://search"
                            type="Emphasized"
                            press=".onSearch"
                            class="sapUiTinyMarginEnd sapUiTinyMarginBottom" />
                        <Button
                            text="초기화"
                            icon="sap-icon://reset"
                            press=".onResetSearch"
                            class="sapUiTinyMarginBottom" />
                    </HBox>
                </VBox>
            </Panel>
            <t:Table
            id="prodOrderTable"
            visibleRowCount="10"
            rows="{/ProdOrderSet}"
            selectionMode="Single"
            selectionBehavior="RowOnly"
            ariaLabelledBy="title">
            <t:extension>
                <OverflowToolbar style="Clear">
                    <Title id="title" text="생산 오더"/>
                </OverflowToolbar>
            </t:extension>
            <t:columns>
                <t:Column width="8rem" hAlign="Center">
                    <Label text="생산 상태" />
                    <t:template>
                        <ObjectStatus
                            text="{path: 'Stat', formatter: '.formatProdStatusText'}"
                            state="{path: 'Stat', formatter: '.formatProdStatusState'}" />
                    </t:template>
                </t:Column>
                <t:Column width="8rem" hAlign="Center">
                    <Label text="생산 오더 번호" />
                    <t:template>
                        <Text text="{Aufnr}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="8rem">
                    <Label text="자재 번호" />
                    <t:template>
                        <Text text="{Plnbez}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="12rem">
                    <Label text="자재명" />
                    <t:template>
                        <Text text="{Maktx}" wrapping="false" />
                    </t:template>
                </t:Column>
                <!-- <t:Column width="8rem">
                    <Label text="배치번호" />
                    <t:template>
                        <Text text="{Charg}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="8rem">
                    <Label text="BOM ID" />
                    <t:template>
                        <Text text="{Stlnr}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="8rem">
                    <Label text="공정 ID" />
                    <t:template>
                        <Text text="{Plnnr}" wrapping="false" />
                    </t:template>
                </t:Column> -->
                <t:Column width="8rem">
                    <Label text="생산 지시 수량" />
                    <t:template>
                        <Text text="{
                            parts:[{path:'Gamng'},{path:'Meins'}],
                            type: 'sap.ui.model.type.Unit',
                            formatOptions: {showMeasure: true }
                            }" wrapping="false" />
                    </t:template>
                </t:Column>
               <!-- <t:Column width="4rem">
                    <Label text="단위" />
                    <t:template>
                        <Text text="{Meins}" wrapping="false" />
                    </t:template>
                </t:Column> -->
              <!--  <t:Column width="7rem">
                    <Label text="승인 상태" />
                    <t:template>
                        <Text text="{Apstat}" wrapping="false" />
                    </t:template>
                </t:Column> -->
                <t:Column width="8rem">
                    <Label text="계획 시작일" />
                    <t:template>
                        <Text text="{Gstrp}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="8rem">
                    <Label text="계획 완료일" />
                    <t:template>
                        <Text text="{Gltrp}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="8rem">
                    <Label text="오더 생성일" />
                    <t:template>
                        <Text text="{Ordat}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="6rem" hAlign="Center">
                    <Label text="생산지시" />
                    <t:template>
                        <Button
                            text="지시"
                            icon="sap-icon://media-play"
                            type="Default"
                            class="prodInstructionButton"
                            press=".onPressProdInstruction" />
                    </t:template>
                </t:Column>
                <t:Column width="4rem" hAlign="Center">
                    <Label text="상세" />
                    <t:template>
                        <Button icon="sap-icon://navigation-right-arrow" type="Transparent" tooltip="생산 상세" press=".onPressProdDetail" />
                    </t:template>
                </t:Column>
            </t:columns>
        </t:Table>
        </VBox>
    </Page>
</mvc:View>
