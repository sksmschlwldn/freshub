<mvc:View controllerName="zpe2.pp002.zpe2pp002.controller.ProdOrderDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="prodOrderDetailPage" title="생산오더 상세" showNavButton="true" navButtonPress=".onNavBack">
        <VBox class="sapUiSmallMargin">
            <Panel expandable="false" class="sapUiNoContentPadding prodDetailSummaryPanel">
                <VBox class="prodDetailSummary">
                    <HBox alignItems="Center" wrap="Wrap" class="prodDetailSummaryTop">
                        <VBox width="20rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                            <HBox alignItems="Center">
                                <Title text="{Aufnr}" level="H1" titleStyle="H3" class="sapUiTinyMarginEnd" />
                                <ObjectStatus
                                    text="{path: 'Stat', formatter: '.formatProdStatusText'}"
                                    state="{path: 'Stat', formatter: '.formatProdStatusState'}"
                                    class="prodDetailStatusPill" />
                            </HBox>
                            <HBox alignItems="Center" wrap="Wrap" class="prodDetailMaterialText">
                                <Text text="자재번호 {Plnbez}" wrapping="false" class="sapUiTinyMarginEnd" />
                                <Text text="|" class="sapUiTinyMarginEnd" />
                                <Text text="자재명 {Maktx}" wrapping="false" />
                            </HBox>
                        </VBox>

                        <VBox width="8rem" class="prodDetailSummaryItem">
                            <Label text="지시 수량" />
                            <Text
                                text="{
                                    parts:[{path:'Gamng'},{path:'Meins'}],
                                    formatter: '.formatQuantity'
                                }"
                                wrapping="false" />
                        </VBox>
                        <VBox width="16rem" class="prodDetailSummaryItem">
                            <Label text="계획 기간" />
                            <Text
                                text="{
                                    parts:[{path:'Gstrp'},{path:'Gltrp'}],
                                    formatter: '.formatDateRange'
                                }"
                                wrapping="false" />
                        </VBox>
                        <VBox width="12rem" class="prodDetailSummaryItem">
                            <Label text="생산공정" />
                            <Text text="{detail>/routeHeader/KtextR}" wrapping="false" />
                        </VBox>
                        <VBox width="6rem" class="prodDetailSummaryItem">
                            <Label text="플랜트" />
                            <Text text="{detail>/routeHeader/Werks}" wrapping="false" />
                        </VBox>
                        <VBox width="12rem" class="prodDetailSummaryItem">
                            <Label text="생산공정ID" />
                            <Text text="{detail>/routeHeader/Plnnr}" wrapping="false" />
                        </VBox>
                    </HBox>
                </VBox>
            </Panel>

            <IconTabBar
                class="sapUiSmallMarginTop"
                expandable="false"
                upperCase="false"
                selectedKey="performance">
                <items>
                    <IconTabFilter key="performance" text="생산실적">
                        <Panel headerText="생산실적" expandable="false" class="sapUiNoContentPadding prodDetailTabPanel">
                <t:Table
                    id="prodRoutTable"
                    visibleRowCount="6"
                    rows="{detail>/routs}"
                    selectionMode="None">
                    <t:columns>
                        <t:Column width="7rem" hAlign="Center">
                            <Label text="공정 순서" />
                            <t:template>
                                <Text text="{detail>Vornr}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="12rem">
                            <Label text="작업장" />
                            <t:template>
                                <Text text="{detail>KtextW}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="14rem">
                            <Label text="작업명" />
                            <t:template>
                                <Text text="{detail>Ltxa1}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="10rem" hAlign="Center">
                            <Label text="작업시작일" />
                            <t:template>
                                <DatePicker
                                    value="{detail>Isdd}"
                                    width="8.5rem"
                                    class="prodTimeInput"
                                    displayFormat="yyyy.MM.dd"
                                    valueFormat="yyyy-MM-dd"
                                    enabled="{path: 'Stat', formatter: '.formatPerformanceEditable'}"
                                    change=".onPerformanceTimeChange" />
                            </t:template>
                        </t:Column>
                        <t:Column width="9rem" hAlign="Center">
                            <Label text="시작시간" />
                            <t:template>
                                <TimePicker
                                    value="{detail>Isdz}"
                                    width="7.5rem"
                                    class="prodTimeInput"
                                    displayFormat="HH:mm:ss"
                                    valueFormat="HH:mm:ss"
                                    enabled="{path: 'Stat', formatter: '.formatPerformanceEditable'}"
                                    change=".onPerformanceTimeChange" />
                            </t:template>
                        </t:Column>
                        <t:Column width="10rem" hAlign="Center">
                            <Label text="종료일" />
                            <t:template>
                                <DatePicker
                                    value="{detail>Iedd}"
                                    width="8.5rem"
                                    class="prodTimeInput"
                                    displayFormat="yyyy.MM.dd"
                                    valueFormat="yyyy-MM-dd"
                                    enabled="{path: 'Stat', formatter: '.formatPerformanceEditable'}"
                                    change=".onPerformanceTimeChange" />
                            </t:template>
                        </t:Column>
                        <t:Column width="9rem" hAlign="Center">
                            <Label text="종료 시간" />
                            <t:template>
                                <TimePicker
                                    value="{detail>Iedz}"
                                    width="7.5rem"
                                    class="prodTimeInput"
                                    displayFormat="HH:mm:ss"
                                    valueFormat="HH:mm:ss"
                                    enabled="{path: 'Stat', formatter: '.formatPerformanceEditable'}"
                                    change=".onPerformanceTimeChange" />
                            </t:template>
                        </t:Column>
                        <t:Column width="7rem">
                            <Label text="걸린시간" />
                            <t:template>
                                <ObjectNumber number="{detail>Ismnw}" unit="분" />
                            </t:template>
                        </t:Column>
                        <t:Column width="8rem" hAlign="Center">
                            <Label text="실적" />
                            <t:template>
                                <HBox justifyContent="Center">
                                    <Button
                                        text="실적등록"
                                        type="Emphasized"
                                        visible="{
                                            parts:[
                                                {path:'Stat'},
                                                {path:'detail>_registered'}
                                            ],
                                            formatter: '.formatRegisterButtonVisible'
                                        }"
                                        press=".onPressRegisterPerformance" />
                                    <Button
                                        icon="sap-icon://edit"
                                        type="Transparent"
                                        tooltip="수정"
                                        visible="{
                                            parts:[
                                                {path:'Stat'},
                                                {path:'detail>_registered'},
                                                {path:'detail>Isdd'},
                                                {path:'detail>Isdz'},
                                                {path:'detail>Iedd'},
                                                {path:'detail>Iedz'}
                                            ],
                                            formatter: '.formatChangeButtonsVisible'
                                        }"
                                        press=".onPressEditPerformance" />
                                    <Button
                                        icon="sap-icon://delete"
                                        type="Transparent"
                                        tooltip="삭제"
                                        visible="{
                                            parts:[
                                                {path:'Stat'},
                                                {path:'detail>_registered'},
                                                {path:'detail>Isdd'},
                                                {path:'detail>Isdz'},
                                                {path:'detail>Iedd'},
                                                {path:'detail>Iedz'}
                                            ],
                                            formatter: '.formatChangeButtonsVisible'
                                        }"
                                        press=".onPressDeletePerformance" />
                                </HBox>
                            </t:template>
                        </t:Column>
                    </t:columns>
                </t:Table>
                <HBox justifyContent="End" class="prodDetailCompleteBar">
                    <Button
                        text="생산완료"
                        icon="sap-icon://complete"
                        type="Emphasized"
                        enabled="{
                            parts:[
                                {path:'Stat'},
                                {path:'detail>/allRegistered'}
                            ],
                            formatter: '.formatCompleteButtonEnabled'
                        }"
                        press=".onPressCompleteProduction" />
                </HBox>
                        </Panel>
                    </IconTabFilter>

                    <IconTabFilter key="materials" text="자재사용">
                        <Panel headerText="자재사용" expandable="false" class="sapUiNoContentPadding prodDetailTabPanel">
                            <t:Table
                                id="prodItemTable"
                                visibleRowCount="5"
                                rows="{detail>/items}"
                                selectionMode="None">
                                <t:columns>
                                    <t:Column width="8rem">
                                        <Label text="배치번호" />
                                        <t:template>
                                            <Text text="{detail>Charg}" wrapping="false" />
                                        </t:template>
                                    </t:Column>
                                    <t:Column width="10rem">
                                        <Label text="자재번호" />
                                        <t:template>
                                            <Text text="{detail>Matnr}" wrapping="false" />
                                        </t:template>
                                    </t:Column>
                                    <t:Column width="16rem">
                                        <Label text="자재명" />
                                        <t:template>
                                            <Text text="{detail>Maktx}" wrapping="false" />
                                        </t:template>
                                    </t:Column>
                                    <t:Column width="9rem">
                                        <Label text="투입 수량" />
                                        <t:template>
                                            <ObjectNumber
                                                number="{detail>Bdmng}"
                                                unit="{detail>Meins}" />
                                        </t:template>
                                    </t:Column>
                                 <!--<t:Column width="6rem">
                                        <Label text="단위" />
                                        <t:template>
                                            <Text text="{detail>Meins}" wrapping="false" />
                                        </t:template>
                                    </t:Column>-->   
                                </t:columns>
                            </t:Table>
                        </Panel>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </VBox>
    </Page>
</mvc:View>
