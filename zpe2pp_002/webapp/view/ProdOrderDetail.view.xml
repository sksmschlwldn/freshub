<mvc:View controllerName="zpe2.pp002.zpe2pp002.controller.ProdOrderDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="prodOrderDetailPage" title="생산오더 상세" showNavButton="true" navButtonPress=".onNavBack">
        <VBox class="sapUiSmallMargin">
            <Panel headerText="생산오더 정보" expandable="false" class="sapUiNoContentPadding">
                <VBox>
                    <ObjectHeader
                        title="{Aufnr}"
                        number="{
                            parts:[{path:'Gamng'},{path:'Meins'}],
                            formatter: '.formatQuantity'
                        }"
                        numberUnit="지시수량"
                        responsive="true">
                        <attributes>
                            <ObjectAttribute title="자재번호" text="{Plnbez}" />
                            <ObjectAttribute title="자재명" text="{Maktx}" />
                            <ObjectAttribute
                                title="계획일"
                                text="{
                                    parts:[{path:'Gstrp'},{path:'Gltrp'}],
                                    formatter: '.formatDateRange'
                                }" />
                        </attributes>
                        <statuses>
                            <ObjectStatus
                                title="생산 상태"
                                text="{path: 'Stat', formatter: '.formatProdStatusText'}"
                                state="{path: 'Stat', formatter: '.formatProdStatusState'}" />
                        </statuses>
                    </ObjectHeader>

                    <VBox class="sapUiSmallMargin prodDetailInfo">
                        <Title text="공정 정보" level="H3" titleStyle="H5" />
                        <HBox wrap="Wrap" class="prodDetailInfoLine" alignItems="Start">
                            <VBox class="prodDetailTextField">
                                <Label text="플랜트" />
                                <Text text="{detail>/routeHeader/Werks}" />
                            </VBox>
                            <VBox class="prodDetailTextField">
                                <Label text="생산공정ID" />
                                <Text text="{detail>/routeHeader/Plnnr}" />
                            </VBox>
                            <VBox class="prodDetailTextField prodDetailTextWideField">
                                <Label text="생산공정명" />
                                <Text text="{detail>/routeHeader/KtextR}" />
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
            </Panel>

            <Panel headerText="공정 실적" expandable="false" class="sapUiSmallMarginTop">
                <t:Table
                    id="prodRoutTable"
                    visibleRowCount="6"
                    rows="{detail>/routs}"
                    selectionMode="None"
                    ariaLabelledBy="prodRoutTitle">
                    <t:extension>
                        <OverflowToolbar style="Clear">
                            <Title id="prodRoutTitle" text="공정 실적 입력" />
                        </OverflowToolbar>
                    </t:extension>
                    <t:columns>
                        <t:Column width="7rem" hAlign="Center">
                            <Label text="공정 순서" />
                            <t:template>
                                <Text text="{detail>Vornr}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="12rem">
                            <Label text="작업장" />
                            <t:template>
                                <Text text="{detail>KtextW}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="14rem">
                            <Label text="작업명" />
                            <t:template>
                                <Text text="{detail>Ltxa1}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="10rem" hAlign="Center">
                            <Label text="작업시작일" />
                            <t:template>
                                <DatePicker
                                    value="{detail>Isdd}"
                                    width="8.5rem"
                                    class="prodTimeInput"
                                    displayFormat="yyyy.MM.dd"
                                    valueFormat="yyyy-MM-dd"
                                    enabled="{path: 'Stat', formatter: '.formatPerformanceEditable'}"
                                    change=".onPerformanceTimeChange" />
                            </t:template>
                        </t:Column>
                        <t:Column width="9rem" hAlign="Center">
                            <Label text="시작시간" />
                            <t:template>
                                <TimePicker
                                    value="{detail>Isdz}"
                                    width="7.5rem"
                                    class="prodTimeInput"
                                    displayFormat="HH:mm:ss"
                                    valueFormat="HH:mm:ss"
                                    enabled="{path: 'Stat', formatter: '.formatPerformanceEditable'}"
                                    change=".onPerformanceTimeChange" />
                            </t:template>
                        </t:Column>
                        <t:Column width="10rem" hAlign="Center">
                            <Label text="종료일" />
                            <t:template>
                                <DatePicker
                                    value="{detail>Iedd}"
                                    width="8.5rem"
                                    class="prodTimeInput"
                                    displayFormat="yyyy.MM.dd"
                                    valueFormat="yyyy-MM-dd"
                                    enabled="{path: 'Stat', formatter: '.formatPerformanceEditable'}"
                                    change=".onPerformanceTimeChange" />
                            </t:template>
                        </t:Column>
                        <t:Column width="9rem" hAlign="Center">
                            <Label text="종료 시간" />
                            <t:template>
                                <TimePicker
                                    value="{detail>Iedz}"
                                    width="7.5rem"
                                    class="prodTimeInput"
                                    displayFormat="HH:mm:ss"
                                    valueFormat="HH:mm:ss"
                                    enabled="{path: 'Stat', formatter: '.formatPerformanceEditable'}"
                                    change=".onPerformanceTimeChange" />
                            </t:template>
                        </t:Column>
                        <t:Column width="7rem">
                            <Label text="걸린시간" />
                            <t:template>
                                <ObjectNumber number="{detail>Ismnw}" unit="분" />
                            </t:template>
                        </t:Column>
                        <t:Column width="8rem" hAlign="Center">
                            <Label text="실적" />
                            <t:template>
                                <HBox justifyContent="Center">
                                    <Button
                                        text="실적등록"
                                        type="Emphasized"
                                        visible="{
                                            parts:[
                                                {path:'Stat'},
                                                {path:'detail>_registered'}
                                            ],
                                            formatter: '.formatRegisterButtonVisible'
                                        }"
                                        press=".onPressRegisterPerformance" />
                                    <Button
                                        icon="sap-icon://edit"
                                        type="Transparent"
                                        tooltip="수정"
                                        visible="{
                                            parts:[
                                                {path:'Stat'},
                                                {path:'detail>_registered'},
                                                {path:'detail>Isdd'},
                                                {path:'detail>Isdz'},
                                                {path:'detail>Iedd'},
                                                {path:'detail>Iedz'}
                                            ],
                                            formatter: '.formatChangeButtonsVisible'
                                        }"
                                        press=".onPressEditPerformance" />
                                    <Button
                                        icon="sap-icon://delete"
                                        type="Transparent"
                                        tooltip="삭제"
                                        visible="{
                                            parts:[
                                                {path:'Stat'},
                                                {path:'detail>_registered'},
                                                {path:'detail>Isdd'},
                                                {path:'detail>Isdz'},
                                                {path:'detail>Iedd'},
                                                {path:'detail>Iedz'}
                                            ],
                                            formatter: '.formatChangeButtonsVisible'
                                        }"
                                        press=".onPressDeletePerformance" />
                                </HBox>
                            </t:template>
                        </t:Column>
                    </t:columns>
                </t:Table>
                <HBox justifyContent="End" class="sapUiSmallMarginTop">
                    <Button
                        text="생산완료"
                        icon="sap-icon://complete"
                        type="Emphasized"
                        enabled="{
                            parts:[
                                {path:'Stat'},
                                {path:'detail>/allRegistered'}
                            ],
                            formatter: '.formatCompleteButtonEnabled'
                        }"
                        press=".onPressCompleteProduction" />
                </HBox>
            </Panel>

            <Panel headerText="배치별 투입 재고" expandable="false" class="sapUiSmallMarginTop">
                <t:Table
                    id="prodItemTable"
                    visibleRowCount="5"
                    rows="{detail>/items}"
                    selectionMode="None"
                    ariaLabelledBy="prodItemTitle">
                    <t:extension>
                        <OverflowToolbar style="Clear">
                            <Title id="prodItemTitle" text="생산 투입 자재" />
                        </OverflowToolbar>
                    </t:extension>
                    <t:columns>
                        <t:Column width="8rem">
                            <Label text="배치번호" />
                            <t:template>
                                <Text text="{detail>Charg}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="10rem">
                            <Label text="자재번호" />
                            <t:template>
                                <Text text="{detail>Matnr}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="16rem">
                            <Label text="자재명" />
                            <t:template>
                                <Text text="{detail>Maktx}" wrapping="false" />
                            </t:template>
                        </t:Column>
                        <t:Column width="9rem">
                            <Label text="투입 수량" />
                            <t:template>
                                <ObjectNumber
                                    number="{detail>Bdmng}"
                                    unit="{detail>Meins}" />
                            </t:template>
                        </t:Column>
                     <!--<t:Column width="6rem">
                            <Label text="단위" />
                            <t:template>
                                <Text text="{detail>Meins}" wrapping="false" />
                            </t:template>
                        </t:Column>-->   
                    </t:columns>
                </t:Table>
            </Panel>
        </VBox>
    </Page>
</mvc:View>
