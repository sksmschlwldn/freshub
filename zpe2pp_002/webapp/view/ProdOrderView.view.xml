<mvc:View controllerName="zpe2.pp002.zpe2pp002.controller.ProdOrderView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page id="page" showHeader="false">
        <VBox class="sapUiSmallMargin">
            <Panel headerText="조회 조건" expandable="false" class="prodFilterBar sapUiNoContentPadding sapUiSmallMarginBottom">
                <VBox class="sapUiSmallMargin">
                    <HBox alignItems="End" wrap="Wrap">
                        <VBox width="16rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                            <Label text="생산오더번호" />
                            <Input
                                id="aufnrInput"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpRequest" />
                        </VBox>
                        <VBox width="16rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                            <Label text="자재번호" />
                            <Input
                                id="plnbezInput"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpRequest" />
                        </VBox>
                        <VBox width="21rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                            <Label text="생산계획일" />
                            <HBox alignItems="Center">
                                <DatePicker
                                    id="gstrpFromDate"
                                    width="9rem"
                                    placeholder="시작일"
                                    displayFormat="yyyy.MM.dd"
                                    valueFormat="yyyyMMdd" />
                                <Text text="~" class="sapUiTinyMarginBeginEnd" />
                                <DatePicker
                                    id="gstrpToDate"
                                    width="9rem"
                                    placeholder="종료일"
                                    displayFormat="yyyy.MM.dd"
                                    valueFormat="yyyyMMdd" />
                            </HBox>
                        </VBox>
                        <VBox width="18rem" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                            <Label text="생산상태" />
                            <MultiComboBox
                                id="statMultiComboBox"
                                width="100%"
                                placeholder="Multi-ComboBox">
                                <core:Item key="1" text="진행중 (In Process)" />
                                <core:Item key="0" text="생산전 (Before Production)" />
                                <core:Item key="2" text="완료 (Completed)" />
                            </MultiComboBox>
                        </VBox>
                        <Button
                            text="검색"
                            type="Emphasized"
                            press=".onSearch"
                            class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                            width="4rem" />
                        <Button
                            text="초기화"
                            press=".onResetSearch"
                            class="sapUiTinyMarginBottom" 
                            width="4rem" />
                    </HBox>
                </VBox>
            </Panel>

            <t:Table
            id="prodOrderTable"
            visibleRowCount="15"
            rows="{/ProdOrderSet}"
            selectionMode="Single"
            selectionBehavior="RowOnly"
            ariaLabelledBy="title">
            <t:extension>
                <OverflowToolbar style="Clear">
                    <Title id="title" text="생산 오더"/>
                </OverflowToolbar>
            </t:extension>
            <t:columns>
                <t:Column width="10rem" hAlign="Center">
                    <Label text="생산 오더 번호" />
                    <t:template>
                        <Text text="{Aufnr}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="8rem" hAlign="Center">
                    <Label text="자재 번호" />
                    <t:template>
                        <Text text="{Plnbez}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="14rem">
                    <Label text="자재명" />
                    <t:template>
                        <Text text="{Maktx}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="8rem" >
                    <Label text="생산 상태" />
                    <t:template>
                        <ObjectStatus
                            text="{path: 'Stat', formatter: '.formatProdStatusText'}"
                            class="prodStatusText"
                            state="{path: 'Stat', formatter: '.formatProdStatusState'}" />
                    </t:template>
                </t:Column>
                <t:Column width="8rem">
                    <Label text="생산 지시 수량" />
                    <t:template>
                        <Text text="{
                            parts:[{path:'Gamng'},{path:'Meins'}],
                            type: 'sap.ui.model.type.Unit',
                            formatOptions: {showMeasure: true }
                            }" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="8rem">
                    <Label text="계획 시작일" />
                    <t:template>
                        <Text text="{Gstrp}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="8rem">
                    <Label text="계획 완료일" />
                    <t:template>
                        <Text text="{Gltrp}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="8rem">
                    <Label text="오더 생성일" />
                    <t:template>
                        <Text text="{Ordat}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="7rem" hAlign="Center">
                    <Label text="생산 지시" />
                    <t:template>
                        <Button
                            text="지시"
                            icon="sap-icon://media-play"
                            type="Default"
                            class="prodInstructionButton"
                            visible="{path: 'Stat', formatter: '.formatProdInstructionVisible'}"
                            press=".onPressProdInstruction" />
                    </t:template>
                </t:Column>
                <t:Column width="5rem" hAlign="Center">
                    <Label text="상세" />
                    <t:template>
                        <Button
                            icon="sap-icon://navigation-right-arrow"
                            type="Transparent"
                            tooltip="상세"
                            press=".onPressProdDetail" />
                    </t:template>
                </t:Column>
            </t:columns>
        </t:Table>
        </VBox>
    </Page>
</mvc:View>
